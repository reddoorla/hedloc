{
  "name": "sveltekit-starter-prismic-minimal",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.12.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "concurrently \"pnpm:vite:dev\" \"pnpm:slicemachine\" --prefix-colors blue,magenta",
    "vite:dev": "vite dev",
    "vite:devHost": "vite dev --host --port 8888",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "lint": "prettier --check . && eslint .",
    "format": "prettier --write .",
    "slicemachine": "start-slicemachine",
    "test:smoke": "playwright install chromium && playwright test"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@eslint/js": "^10.0.1",
    "@lhci/cli": "^0.15.1",
    "@playwright/test": "^1.60.0",
    "@reddoorla/maintenance": "^0.69.0",
    "@slicemachine/adapter-sveltekit": "^0.3.96",
    "@sveltejs/adapter-netlify": "^6.0.4",
    "@sveltejs/kit": "^2.61.1",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "concurrently": "^9.2.1",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-svelte": "^3.18.0",
    "globals": "^17.6.0",
    "prettier": "^3.8.3",
    "prettier-plugin-svelte": "^4.0.1",
    "slice-machine-ui": "^2.21.3",
    "svelte": "^5.55.10",
    "svelte-check": "^4.4.8",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.0",
    "typescript-svelte-plugin": "^0.3.52",
    "vite": "^8.0.14"
  },
  "dependencies": {
    "@prismicio/client": "^7.3.1",
    "@prismicio/svelte": "^2.2.1",
    "@tailwindcss/vite": "^4.3.0",
    "@lucide/svelte": "^1.17.0",
    "svelte-gestures": "^5.0.7",
    "svelte-select": "^5.8.3"
  }
}
