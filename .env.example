# Central reddoor-fleet contact-form ingest.
# The contact form posts to this endpoint (see
# src/routes/[[preview=preview]]/contact/+page.server.ts). The endpoint persists
# the submission and emails the site's configured recipient via the dashboard's
# Resend integration. Set BOTH in the Netlify site env — never commit real values.
#
# <slug> must match how this site is registered in the "Reddoor Websites"
# Airtable base; that Airtable row is ALSO where the notification recipient email
# is configured. Until the site is registered there, submissions 404 ("unknown-site").
FORMS_INGEST_URL=https://reddoor-maintenance.netlify.app/api/forms/hedloc
# Shared fleet secret (same value across every fleet site + reddoor-maintenance).
FORMS_INGEST_TOKEN=replace-with-the-shared-fleet-secret
